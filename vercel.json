{
  "framework": null,
  "functions": {
    "api/chat.js": {
      "maxDuration": 60
    },
    "api/*.js": {
      "maxDuration": 10
    },
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/auth/login",         "destination": "/api/auth?action=login" },
    { "source": "/api/auth/signup",        "destination": "/api/auth?action=signup" },
    { "source": "/api/auth/user",          "destination": "/api/auth?action=user" },
    { "source": "/api/auth/send-2fa-code", "destination": "/api/auth?action=send-2fa-code" },
    { "source": "/api/auth/verify-2fa",   "destination": "/api/auth?action=verify-2fa" },
    { "source": "/app",  "destination": "/app.html"  },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/login","destination": "/auth.html" }
  ]
}









