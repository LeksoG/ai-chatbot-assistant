{
  "framework": null,
  "functions": {
    "api/chat.js": {
      "maxDuration": 60
    },
    "api/*.js": {
      "maxDuration": 30
    },
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/app",  "destination": "/app.html"  },
    { "source": "/auth", "destination": "/auth.html" },
    { "source": "/login","destination": "/auth.html" }
  ]
}


